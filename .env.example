# ─────────────────────────────────────────────────────────────────────────────
# LOCAL DEVELOPMENT (docker-compose)
# Copy this file to .env in the repo root and fill in the blanks. Docker
# defaults are pre-filled. This is the ONLY .env file you need — docker-compose
# passes it into every service (db, backend, worker, frontend) via `env_file:`,
# so there's no separate backend/.env or frontend/.env to keep in sync.
# (If you run the frontend or backend directly, outside docker-compose, they
# also fall back to this root .env automatically.)
# ─────────────────────────────────────────────────────────────────────────────

# Backend
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/ssicsim
REDIS_URL=redis://redis:6379/0
API_CORS_ORIGINS=http://localhost:3000
ENVIRONMENT=development

# Postgres (docker-compose only — not used by Render or Supabase)
POSTGRES_DB=ssicsim
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Frontend (Next.js)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=                        # openssl rand -base64 32
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ADMIN_EMAIL_ALLOWLIST=admin@example.com
ADMIN_API_TOKEN=change-me               # openssl rand -hex 32
# BACKEND_BASE_URL is read server-side, inside the frontend container, so it
# must use the docker-compose service name, not localhost.
BACKEND_BASE_URL=http://backend:8000
# NEXT_PUBLIC_API_BASE_URL is inlined into the browser bundle, so it must be
# reachable from your host machine (the browser is not on the docker network).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# Gmail (use a Google App Password, not your regular password)
# Generate at: https://myaccount.google.com/apppasswords
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-app-password


# ─────────────────────────────────────────────────────────────────────────────
# PRODUCTION — set these in Render (backend) and Vercel (frontend) dashboards.
# Do NOT commit real values here.
# ─────────────────────────────────────────────────────────────────────────────

# Backend (Render environment variables)
# ENVIRONMENT=production
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres
# REDIS_URL=redis://red-xxx:6379                 (Render Redis internal URL)
# API_CORS_ORIGINS=https://admin.ssicsim.ca
# ADMIN_API_TOKEN=                               (openssl rand -hex 32)
# GMAIL_USER=
# GMAIL_APP_PASSWORD=
# FRONTEND_URL=https://admin.ssicsim.ca

# Supabase Storage (Render environment variables)
# SUPABASE_URL=https://[REF].supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_BUCKET=ssicsim-assets
# SUPABASE_PUBLIC_BASE_URL=                      (leave blank to use default Supabase URL)

# Frontend (Vercel environment variables — set scope to Production)
# NEXTAUTH_URL=https://admin.ssicsim.ca
# NEXTAUTH_SECRET=                               (openssl rand -base64 32)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# ADMIN_EMAIL_ALLOWLIST=tech@ssicsim.ca
# ADMIN_API_TOKEN=                               (same value as Render)
# BACKEND_BASE_URL=https://ssicsim-backend.onrender.com
